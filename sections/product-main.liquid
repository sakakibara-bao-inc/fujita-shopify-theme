
  <article class="product-article l-section-gap--after-header-at-sm">
    <div class="product-article__hero c-slider">
      <div class="c-image-strip c-image-strip--shop-item swiper">
        <div class="swiper-wrapper">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <div class="c-image-strip__item swiper-slide">
                {{ media | image_url: width: 1200 | image_tag: alt: media.alt }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="c-slider__controls l-container">
        <button class="c-slider__button c-slider__button--prev" type="button" aria-label="前の画像">
          <span class="c-icon c-icon--chevron-right">
            <svg aria-hidden="true"><use href="#icon-chevron-right"></use></svg>
          </span>
        </button>

        <button class="c-slider__button c-slider__button--next" type="button" aria-label="次の画像">
          <span class="c-icon c-icon--chevron-right">
            <svg aria-hidden="true"><use href="#icon-chevron-right"></use></svg>
          </span>
        </button>
      </div>
    </div>

      
    <!-- l-container -->
    <header class="product-article__header l-container _l-section-gap--xs">
      <div class="product-article__head">
        <p class="product-article__brand">三洋産業</p>
        <h1 class="product-article__title">CAFEC アバカ円錐ペーパーフィルター</h1>
        <p class="product-article__price">
          <span class="product-article__price-main"><span>¥</span>5,000<i>〜</i><span>¥</span>20,000</span>
          <span class="product-article__price-tax">（税込）</span>
        </p>
      </div>

      <div class="product-article__description">
        <p>アバカパルプを使用した、環境にもやさしい円錐型ペーパーフィルターです。1cup／4cup に対応し、すっきりとした味わいとクリアな後味を引き出します。<br>100枚入り<br>Made in Japan</p>
      </div>

      <div class="product-article__controls">
        <form action="/cart/add" method="post" data-product-form>
          <input type="hidden" name="id" value="" data-variant-id>

          <fieldset class="c-product-option">
            <legend class="c-product-option__label">サイズ</legend>

            <div class="c-product-option__list">
              <label class="c-product-option__item">
                <input type="radio" name="options[サイズ]" value="1cup" data-product-option checked>
                <span>1cup</span>
              </label>

              <label class="c-product-option__item">
                <input type="radio" name="options[サイズ]" value="2cup" data-product-option>
                <span>2cup</span>
              </label>
            </div>
          </fieldset>

          <fieldset class="c-product-option">
            <legend class="c-product-option__label">色</legend>

            <div class="c-product-option__list">
              <label class="c-product-option__item">
                <input type="radio" name="options[色]" value="白" data-product-option data-image-id="image-white" checked>
                <span>白</span>
              </label>

              <label class="c-product-option__item">
                <input type="radio" name="options[色]" value="黒" data-product-option data-image-id="image-black">
                <span>黒</span>
              </label>

              <label class="c-product-option__item">
                <input type="radio" name="options[色]" value="生成り" data-product-option data-image-id="image-natural">
                <span>生成り</span>
              </label>
              
            </div>
          </fieldset>

          <div class="c-product-quantity">
            <label class="c-product-quantity__label" for="product-qty">数量</label>

            <div class="c-product-quantity__field">
              <button type="button" class="c-product-quantity__button c-product-quantity__button--minus" aria-label="数量を1減らす">–</button>
              <input id="product-qty" type="number" name="quantity" value="1" min="1" inputmode="numeric" required>
              <button type="button" class="c-product-quantity__button c-product-quantity__button--plus" aria-label="数量を1増やす">＋</button>
            </div>
          </div>


          <div class="product-article__cart-button">
            <button type="submit" class="c-button c-button--primary">
              カートに入れる
              <span class="c-icon c-icon--chevron-right">
                <svg aria-hidden="true"><use href="#icon-chevron-right"></use></svg>
              </span>
            </button>
          </div>
        </form>

        <!-- 問い合わせ -->
        <p class="product-article__contact-link"><a href="#" target="_blank">
          <span class="c-icon"><svg aria-hidden="true"><use href="#icon-mail"></use></svg></span>
          この商品について問合わせる
        </a></p>
      </div>
    </header>
    <!-- // l-container -->


    <div class="l-separator l-section-gap--sm"><span></span></div>


    <!-- l-container -->
    <div class="product-article__body l-container l-section-gap--sm">
      <div class="c-article l-readable">
        <p><img src="/fujita/assets/sample-img02.jpg" alt="" class="alignnone" loading="lazy"></p>

